# Optional — demo mode works without any keys:
# DARWIN_DEMO=1

# Live model runs (Architect + swarm)
# GEMINI_API_KEY=your-gemini-api-key

# WebSocket server (defaults shown)
# HOST=0.0.0.0
# PORT=8765
# PACE_MS=350

# Problem: transportation | f1
# PROBLEM=transportation

# Record / replay a run for offline demos
# RECORD=path/to/run.jsonl
# REPLAY=path/to/run.jsonl
